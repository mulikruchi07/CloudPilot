      "parameters": {
        "jsCode": "// Extract variables\nconst subject = $json.textSubject || \"\";\nconst body = $json.textPlain || $json.textHtml || \"\";\nconst taskType = \"get_bucket\";\n\nlet bucketName = \"\";\n\n// Match from subject: e.g., \"get s3 bucket : demo2178352xds\"\nconst bucketMatchSubject = subject.match(/get\\s*s3\\s*bucket\\s*:\\s*([^\\s]+)/i);\nif (bucketMatchSubject) {\n  bucketName = bucketMatchSubject[1].trim();\n}\n\n// If not found in subject, match from body\nif (!bucketName) {\n  const bucketMatchBody = body.match(/get\\s*s3\\s*bucket\\s*:\\s*([^\\s]+)/i);\n  if (bucketMatchBody) {\n    bucketName = bucketMatchBody[1].trim();\n  }\n}\n\n// Return extracted data\nreturn {\n  json: {\n    task_type: taskType,\n    bucketName\n  }\n};\n"
      },
