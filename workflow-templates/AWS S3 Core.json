    {
      "parameters": {
        "jsCode": "const taskType = $json.task_type || \"\";\nconst bucketName = $json.bucketName || \"\";\nconst objectKey = $json.objectKey || \"\";\nconst status = $json.status || \"success\"; // Assume success by default\nconst errorMsg = $json.error || \"\";\n\n// Map S3 task codes to readable names\nconst taskMap = {\n  create_bucket: \"Create S3 Bucket\",\n  delete_bucket: \"Delete S3 Bucket\",\n  list_buckets: \"List S3 Buckets\",\n  get_object: \"Get S3 Object\",\n  upload_object: \"Upload S3 Object\",\n  delete_object: \"Delete S3 Object\"\n};\n\nlet message = \"\";\nlet subject = \"\";\n\nif (errorMsg || status !== \"success\") {\n    subject = `❌ Failure - ${taskMap[taskType] || \"S3 Task\"}`;\n    message = `❌ ${taskMap[taskType] || \"S3 Task\"} failed.\\n`;\n    if (bucketName) message += `Bucket: ${bucketName}\\n`;\n    if (objectKey) message += `Object: ${objectKey}\\n`;\n    if (errorMsg) message += `Error: ${errorMsg}\\n`;\n} else {\n    subject = `✅ Success - ${taskMap[taskType] || \"S3 Task\"}`;\n    message = `✅ ${taskMap[taskType] || \"S3 Task\"} completed successfully.\\n`;\n    if (bucketName) message += `Bucket: ${bucketName}\\n`;\n    if (objectKey) message += `Object: ${objectKey}\\n`;\n    \n    // Special case for list buckets\n    if (taskType === \"list_buckets\") {\n        const buckets = $input.all().map(item => item.json.name);\n        if (buckets.length > 0) {\n            message += `\\nList of Buckets:\\n${buckets.join(\"\\n\")}`;\n        } else {\n            message += \"\\nNo buckets found.\";\n        }\n    }\n\n    // Special case for get object\n    if (taskType === \"get_object\") {\n        const objectContent = $input.first().json.data || \"\";\n        message += `\\nObject Content:\\n${objectContent}`; \n    }\n}\n\nreturn {\n  json: {\n    subject,\n    body: message\n  }\n};\n"
      },
      "id": "72292a00-b53f-4ee8-9a7e-7821a981b6da",
