    {
      "parameters": {
        "jsCode": "const emailBody = $json[\"textPlain\"] || \"\";\nconst subject = $json[\"subject\"] || \"\";\n\n// --- Extract bucket name only from the email body ---\nconst bucketNameMatch = emailBody.match(/bucket[:\\s]*([a-zA-Z0-9._-]+)/i);\nconst bucketName = bucketNameMatch ? bucketNameMatch[1] : null;\n\n// --- Extract object key if present ---\nconst objectKeyMatch = emailBody.match(/object[:\\s]*([^\\s]+)/i);\nconst objectKey = objectKeyMatch ? objectKeyMatch[1] : null;\n\n// --- Detect task type (from both body and subject) ---\nlet task_type = \"\";\n\nif (/create\\s+(s3\\s+)?bucket/i.test(emailBody) || /create\\s+(s3\\s+)?bucket/i.test(subject)) {\n  task_type = \"create_bucket\";\n} else if (/delete\\s+(s3\\s+)?bucket/i.test(emailBody) || /delete\\s+(s3\\s+)?bucket/i.test(subject)) {\n  task_type = \"delete_bucket\";\n} else if (/list\\s+(s3\\s+)?buckets?/i.test(emailBody) || /list\\s+(s3\\s+)?buckets?/i.test(subject)) {\n  task_type = \"list_buckets\";\n} else if (/get\\s+(s3\\s+)?object/i.test(emailBody) || /get\\s+(s3\\s+)?object/i.test(subject)) {\n  task_type = \"get_object\";\n} else if (/upload\\s+(s3\\s+)?object/i.test(emailBody) || /upload\\s+(s3\\s+)?object/i.test(subject)) {\n  task_type = \"upload_object\";\n} else if (/delete\\s+(s3\\s+)?object/i.test(emailBody) || /delete\\s+(s3\\s+)?object/i.test(subject)) {\n  task_type = \"delete_object\";\n}\n\n// --- Output ---\nreturn [\n  {\n    json: {\n      bucketName,\n      objectKey,\n      task_type,\n    },\n  },\n];\n"
      },
